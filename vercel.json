{
  "version": 2,
  "builds": [
    {
      "src": "backend-gru-hho/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend-gru-hho/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend-gru-hho/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend-gru-hho/$1"
    }
  ]
}
